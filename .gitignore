# ============================================================
# WardSOAR .gitignore — PUBLIC REPO
# ============================================================
# This file is stricter than a typical Python .gitignore because
# the repo is public and WardSOAR processes forensic evidence,
# network captures, and firewall credentials. ANY runtime data
# stays on the operator's machine.

# ============================================================
# Secrets — MUST NEVER be committed
# ============================================================
.env
.env.*
!.env.example
Key/
*.pem
*.p12
*.pfx
*_key
*_key.pub
id_rsa*
id_ed25519*
id_ecdsa*

# ============================================================
# Python
# ============================================================
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.mypy_cache/
.ruff_cache/
.pytest_cache/
.tox/
htmlcov/
.coverage
.coverage.*
*.egg-info/
.eggs/

# ============================================================
# Runtime data (generated by the app, user-specific, not source)
# ============================================================
# Operator-specific or locally-generated state:
block_tracker.json
bootstrap_checklist.json
netgate_baseline.json
prescorer_feedback.json
trusted_temp.json

# Per-instance runtime directories:
data/
evidence/
intel_feeds/
reports/
netgate_backups/
tmp/
snapshots/

# Config snapshots and backups:
configuration/

# Logs — never commit live logs (IPs, network patterns visible)
logs/
*.log
*.jsonl

# SQLite databases (cache, stats)
*.db
*.db-journal
*.db-shm
*.db-wal

# ============================================================
# User config (may contain paths, IPs, preferences)
# ============================================================
config/config.yaml
# Keep the shared configs (these ARE source):
!config/cdn_allowlist.yaml
!config/known_bad_actors.yaml
!config/known_false_positives.yaml
!config/network_baseline.yaml
!config/suspect_asns.yaml
!config/whitelist.yaml

# Captures / pcap / PII artefacts
*.pcap
*.pcapng
*.dmp
eve.json

# Screenshots with IPs / personal info
data/screenshot_*.png
**/screenshot_*.png

# ============================================================
# Build artefacts
# ============================================================
build/
dist/
*.msi
*.wixpdb
.wix/

# ============================================================
# IDE / OS
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
Desktop.ini
.DS_Store
