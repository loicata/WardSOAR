# WardSOAR - API Keys
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# VirusTotal API (free tier: 500 requests/day, 4/min)
VIRUSTOTAL_API_KEY=xxxxx

# pfSense — SSH config is in config.yaml (network.pfsense_ip + responder.pfsense)
# No API keys needed: pfSense 25.x uses SSH+pfctl for all firewall operations
WARD_SSH_KEY_PATH=C:\Users\<your-user>\.ssh\ward_key

# Notifications — Email (optional)
SMTP_USER=
SMTP_PASSWORD=

# Notifications — Telegram (optional)
TELEGRAM_BOT_TOKEN=

# IP reputation (optional)
# ABUSEIPDB_API_KEY=
# OTX_API_KEY=
